# ──────────────────────────────────────────────
#  Variables de entorno — LawyerApp Backend
#  Copiar a .env y completar los valores reales.
#  NUNCA commitear .env ni secrets reales.
# ──────────────────────────────────────────────

# Base de datos Postgres (Neon en prod, local con Docker en dev)
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Dev:  puede ser cualquier string largo
# Prod: secret único y largo, seteado en el dashboard de Render (nunca en archivos)
JWT_SECRET=

# Origen permitido por CORS
# Dev:  http://localhost:5173
# Prod: URL pública del frontend en Vercel (ej. https://lawyerapp.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Puerto del servidor (Render lo inyecta automáticamente en prod)
PORT=3001
